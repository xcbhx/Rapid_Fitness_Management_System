<h2>Class Enrollments</h2>

{{!-- 1. BROWSE TABLE --}}
<table id="enrollments-table" border="1" cellpadding="5">
    <thead>
        <tr>
            <th>Enrollment ID</th>
            <th>Member Name</th>
            <th>Class Name</th>
            <th>Signup Date</th>
            <th>Action</th> </tr>
    </thead>
    <tbody>
        {{#each enrollments}}
        <tr>
            <td>{{this.enrollment_id}}</td>
            <td>{{this.first_name}} {{this.last_name}}</td>
            <td>{{this.class_name}}</td>
            <td>{{this.signup_date}}</td>
            <td>
                <form method="POST" action="/delete-enrollment" style="display:inline;">
                    <input type="hidden" name="enrollment_id" value="{{this.enrollment_id}}">
                    <input type="submit" value="Delete" onclick="return confirm('Are you sure you want to unenroll this member?')">
                </form>
            </td>
        </tr>
        {{/each}}
    </tbody>
</table>

<hr>

{{!-- 2. ADD ENROLLMENT FORM --}}
<h3>Enroll a Member</h3>
<form id="add-enrollment-form" method="POST" action="/add-enrollment">
    <label for="input-member">Member: </label>
    <select name="input-member" id="input-member" required>
        <option value="">Select a member</option>
        {{#each members}}
        <option value="{{this.member_id}}">{{this.first_name}} {{this.last_name}}</option>
        {{/each}}
    </select>

    <label for="input-class">Class: </label>
    <select name="input-class" id="input-class" required>
        <option value="">Select a class</option>
        {{#each classes}}
        <option value="{{this.class_id}}">{{this.class_name}}</option>
        {{/each}}
    </select>

    <input type="submit" value="Enroll Member">
</form>

<hr>

{{!-- 3. UPDATE ENROLLMENT FORM --}}
<h3>Update an Enrollment</h3>
<form id="update-enrollment-form" method="POST" action="/update-enrollment">
    <label for="update-id">Enrollment ID: </label>
    <select name="update-id" id="update-id" required>
        <option value="">Select an ID to update</option>
        {{#each enrollments}}
        <option value="{{this.enrollment_id}}">{{this.enrollment_id}}</option>
        {{/each}}
    </select>

    <label for="update-member">New Member: </label>
    <select name="update-member" id="update-member" required>
        <option value="">Select a member</option>
        {{#each members}}
        <option value="{{this.member_id}}">{{this.first_name}} {{this.last_name}}</option>
        {{/each}}
    </select>

    <label for="update-class">New Class: </label>
    <select name="update-class" id="update-class" required>
        <option value="">Select a class</option>
        {{#each classes}}
        <option value="{{this.class_id}}">{{this.class_name}}</option>
        {{/each}}
    </select>

    <input type="submit" value="Update enrollment">
</form>