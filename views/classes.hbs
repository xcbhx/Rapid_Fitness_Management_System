<h1>Classes</h1>

{{!-- READ Classes Table --}}
<table id="classes_table" border="1" cellpadding="5">
    <thead>
        <tr>
            <th>ID</th>
            <th>Class Name</th>
            <th>Max Capacity</th>
            <th>Trainer Name</th>
            <th>Room Location</th>
            <th>Action</th>
        </tr>
    </thead>

    <tbody>
        {{!-- For each row, print the id, class_name, max_capacity, trainer_id, and room_location --}}
        {{#each classes}}
        <tr>
            <td>{{this.class_id}}</td>
            <td>{{this.class_name}}</td>
            <td>{{this.max_capacity}}</td>
            <td>{{#if this.first_name}}
                    {{this.first_name}} {{this.last_name}}
                {{else}}
                    Unassigned
                {{/if}}
            </td>
            <td>{{this.room_location}}</td>

            <td>
                {{!-- DELETE Class Form--}}
                <form class="delete_class_form" action="/delete-class" method="POST">
                    <input type="hidden" name="class_id" value="{{this.class_id}}" />
                    <input type="hidden" name="class_name" value="{{this.class_name}}" />
                    <input type="submit" value="Delete" class="btn-reset" onclick="return confirm('Remove this class?')">
                </form>
            </td>
        </tr>
        {{/each}}
    </tbody>
</table>

{{!-- CREATE Class Form --}}
<h2>Add a Class</h2>
<form id="create_class_form" action="/classes/create" method="POST">
    <label for="create_class_name">Class Name: </label>
    <input type="text" name="create_class_name" id="create_class_name" required>

    <label for="create_max_capacity">Max Capacity: </label>
    <input type="number" name="create_max_capacity" id="create_max_capacity" required>

    <label for="create_trainer_id">Trainer: </label>
    <select name="create_trainer_id" id="create_trainer_id">
        <option value="0">None</option>
        {{#each trainers}}
        <option value="{{this.trainer_id}}">{{this.first_name}} {{this.last_name}}</option>
        {{/each}}
    </select>

    <label for="create_room_location">Room: </label>
    <input type="text" name="create_room_location" id="create_room_location" required>

    <input type="submit" value="Add Class">
</form>

{{!-- UPDATE Class Form --}}
<h2>Update a Class</h2>
<form id="update_class_form" action="/classes/update" method="POST">
    <label for="update_class_id">Class to Update: </label>
    <select name="update_class_id" id="update_class_id" required>
        <option value="" disabled selected>Select a Class: </option>
        {{#each classes}}
        <option value="{{this.class_id}}" >
            {{this.class_id}}
            -
            {{this.class_name}}
        </option>
        {{/each}}
    </select>

    <label for="update_class_name">Class Name: </label>
    <input type="text" name="update_class_name" id="update_class_name">

    <label for="update_class_max_capacity">Max Capacity: </label>
    <input type="number" name="update_class_max_capacity" id="update_class_max_capacity" />

    {{!-- Foreign Key trainer_id --}}
    <label for="update_class_trainer_id">Assign Trainer: </label>
    <select name="update_class_trainer_id" id="update_class_trainer_id">
        {{!-- Keep exisiting trainer --}}
        <option value="" selected>Keep Current Trainer </option>
        {{!-- Remove trainer --}}
        <option value="-1">Remove Trainer </option>
        {{!-- Assign a different trainer --}}
        {{#each trainers}}
        <option value="{{this.trainer_id}}">{{this.first_name}} {{this.last_name}} </option>
        {{/each}}
    </select>

    <label for="update_room_location">Room Location: </label>
    <input type="text" name="update_room_location" id="update_room_location" />

    <input type="submit" value="Update Class">
</form>