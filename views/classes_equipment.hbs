<h2>Classes and Equipment Assignments</h2>

{{!-- Browse Table --}}
<table border="1" cellpadding="5">
    <thead>
        <tr>
            <th>ID</th>
            <th>Class Name</th>
            <th>Equipment Item</th>
            <th>Action</th>
        </tr>
    </thead>
    <tbody>
        {{#each data}}
        <tr>
            <td>{{this.class_equipment_id}}</td>
            <td>{{this.class_name}}</td>
            <td>{{this.item_name}}</td>
            <td>
                {{!-- Delete form --}}
                <form method="POST" action="/delete-class-equipment" style="display:inline;">
                    <input type="hidden" name="class_equipment_id" value="{{this.class_equipment_id}}">
                    <input type="submit" value="Delete" class="btn-reset" onclick="return confirm('Remove this equipment assignment?')">
                </form>
            </td>
        </tr>
        {{/each}}
    </tbody>
</table>

<hr>

{{!-- CREATE Classes and Equipment form --}}
<h3>Assign Equipment to a Class</h3>
<form method="POST" action="/add_class_equipment">
    <label for="input_class">Class: </label>
    <select name="input_class" id="input_class" required>
        <option value="">Select a Class</option>
        {{#each classes}}
        <option value="{{this.class_id}}">{{this.class_name}}</option>
        {{/each}}
    </select>

    <label for="input_equipment">Equipment: </label>
    <select name="input_equipment" id="input_equipment" required>
        <option value="">Select Equipment</option>
        {{#each equipment_records}}
        <option value="{{this.equipment_id}}">{{this.item_name}}</option>
        {{/each}}
    </select>

    <input type="submit" value="Assign Equipment">
</form>

<hr>

{{!-- UPDATE Assignment Form --}}
<h3>Update an Assignment</h3>
<form method="POST" action="/classes_equipment/update">
    <label for="update_id">Assignment ID: </label>
    <select name="update_id" id="update_id" required>
        <option value="">Select an ID</option>
        {{#each data}}
        <option value="{{this.class_equipment_id}}">{{this.class_equipment_id}}</option>
        {{/each}}
    </select>

    <label for="update_class">New Class: </label>
    <select name="update_class" id="update_class" >
        <option value="">Keep Current Class</option>
        {{#each classes}}
        <option value="{{this.class_id}}">{{this.class_name}}</option>
        {{/each}}
    </select>

    <label for="update_equipment">New Equipment: </label>
    <select name="update_equipment" id="update_equipment" >
        <option value="">Keep Current Equipment</option>
        {{#each equipment_records}}
        <option value="{{this.equipment_id}}">{{this.item_name}}</option>
        {{/each}}
    </select>

    <input type="submit" value="Update Assignment">
</form>