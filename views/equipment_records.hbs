<h2>Equipment Inventory & Maintenance</h2>

{{!-- Browse Table --}}
<table id="equipment-table" border="1" cellpadding="5">
    <thead>
        <tr>
            <th>ID</th>
            <th>Item Name</th>
            <th>Maintenance Status</th>
            <th>Purchase Date</th>
            <th>Location</th>
            <th>Action</th>
        </tr>
    </thead>
    <tbody>
        {{#each equipment_records}}
        <tr>
            <td>{{this.equipment_id}}</td>
            <td>{{this.item_name}}</td>
            <td>{{this.maintenance_status}}</td>
            <td>{{this.purchase_date}}</td>
            <td>{{this.location}}</td>
            <td>
                <form method="POST" action="/delete-equipment" style="display:inline;">
                    <input type="hidden" name="equipment_id" value="{{this.equipment_id}}">
                    <input type="submit" value="Delete" class="btn-reset" onclick="return confirm('Delete this equipment record?')">
                </form>
            </td>
        </tr>
        {{/each}}
    </tbody>
</table>

<hr>

{{!-- UPDATE equipment form --}}
<h3>Update Equipment Status</h3>
<p>Select an item to update its current maintenance status and location.</p>

<form id="update-equipment-form" method="POST" action="/update-equipment">
    <label for="update-id">Item to Update: </label>
    <select name="update-id" id="update-id" required>
        <option value="">Select Equipment</option>
        {{#each equipment_records}}
        <option value="{{this.equipment_id}}">{{this.equipment_id}}: {{this.item_name}}</option>
        {{/each}}
    </select>

    <label for="update-name">New Item Name: </label>
    <input type="text" name="update-name" id="update-name">

    <label for="update-status">Maintenance Status: </label>
    <select name="update-status" id="update-status">
        <option value="Good">Good</option>
        <option value="Needs repair">Needs repair</option>
        <option value="Out of Order">Out of Order</option>
    </select>

    <label for="update-location">New Location: </label>
    <input type="text" name="update-location" id="update-location">

    <input type="submit" value="Update Equipment">
</form>

<hr>

{{!-- Add Equipment Form --}}
<h3>Add New Equipment</h3>
<form id="add-equipment-form" method="POST" action="/add-equipment">
    <label for="item_name">Item Name:</label>
    <input type="text" name="item_name" id="item_name" required>

    <label for="maintenance_status">Status:</label>
    <select name="maintenance_status" id="maintenance_status" required>
        <option value="Good">Good</option>
        <option value="Needs repair">Needs repair</option>
        <option value="In maintenance">In maintenance</option>
    </select>

    <label for="purchase_date">Purchase Date:</label>
    <input type="date" name="purchase_date" id="purchase_date" required>

    <label for="location">Location:</label>
    <input type="text" name="location" id="location" placeholder="e.g. Cardio Zone" required>

    <input type="submit" value="Add Equipment">
</form>