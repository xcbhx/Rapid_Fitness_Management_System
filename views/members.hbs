<h2>Gym Members</h2>

{{!-- 1. The Browse Table --}}
<table id="members-table" border="1" cellpadding="5">
    <thead>
        <tr>
            <th>ID</th>
            <th>First Name</th>
            <th>Last Name</th>
            <th>Email</th>
            <th>Phone Number</th>
            <th>Trainer</th>
            <th>Membership Start Date</th>
            <th>Action</th>
        </tr>
    </thead>
    <tbody>
        {{#each members}}
        <tr>
            <td>{{this.member_id}}</td>
            <td>{{this.first_name}}</td>
            <td>{{this.last_name}}</td>
            <td>{{this.email}}</td>
            <td>{{this.phone_number}}</td>
            <td> {{!-- if trainer exists--}}
                {{#if this.trainer_first}}
                    {{this.trainer_first}} {{this.trainer_last}}
                {{else}}
                    None
                {{/if}}
            </td>
            <td>{{this.membership_start_date}}</td>
            <td>
                {{!-- delete form --}}
                <form method="POST" action="/delete-member" style="display:inline;">
                    <input type="hidden" name="member_id" value="{{this.member_id}}">
                    <input type="submit" value="Delete" class="btn-reset" onclick="return confirm('Are you sure you want to delete this member?')">                 </form>
            </td>
        </tr>
        {{/each}}
    </tbody>
</table>

<hr>
{{!-- UPDATE member form --}}
<h3>Update an Existing Member</h3>
<p>Select a member from the dropdown and enter their new details.</p>

<form id="update-member-form" method="POST" action="/update-member">
    {{!-- Selection dropdown for ID --}}
    <label for="update-id">Member to Update: </label>
    <select name="update-id" id="update-id" required>
        <option value="">Select a Member</option>
        {{#each members}}
        <option value="{{this.member_id}}">{{this.member_id}}: {{this.first_name}} {{this.last_name}}</option>
        {{/each}}
    </select>

    <label for="update-fname">New First Name: </label>
    <input type="text" name="update-fname" id="update-fname" required>

    <label for="update-lname">New Last Name: </label>
    <input type="text" name="update-lname" id="update-lname" required>

    <label for="update-email">New Email: </label>
    <input type="email" name="update-email" id="update-email" required>

    <label for="update-phone">New Phone Number: </label>
    <input type="tel" name="update-phone" id="update-phone">

    <label for="update-trainer">New Assigned Trainer: </label>
    <select name="update-trainer" id="update-trainer">
        <option value="">None (Optional)</option>
        {{#each trainers}}
        <option value="{{this.trainer_id}}">{{this.first_name}} {{this.last_name}}</option>
        {{/each}}
    </select>

    <input type="submit" value="Update Member">
</form>

<hr>

{{!-- Add Member Form --}}
<h3>Add a New Member</h3>
<form id="add-member-form" method="POST" action="/add-member">
    <label for="first_name">First Name:</label>
    <input type="text" name="input-fname" id="first_name" required>

    <label for="last_name">Last Name:</label>
    <input type="text" name="input-lname" id="last_name" required>

    <label for="email">Email:</label>
    <input type="email" name="input-email" id="email" required>

    <label for="input-phone">Phone Number: </label>
    <input type="tel" name="input-phone" id="input-phone" placeholder="503-555-1234">

    <label for="join_date">Membership Start Date:</label>
    <input type="date" name="input-start-date" id="membership_start_date" required>

    {{!-- Dropdown for FK --}}
    <label for="trainer_id">Assigned Trainer:</label>
    <select name="input-trainer" id="trainer_id">
        <option value="">None (Optional)</option>
        {{#each trainers}}
        <option value="{{this.trainer_id}}">{{this.first_name}} {{this.last_name}}</option>
        {{/each}}
    </select>

    <input type="submit" value="Add Member">
</form>